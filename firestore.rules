rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ USERS — Le Créateur lui-même ═══
    match /users/{userId} {
      // Le propriétaire peut tout faire.
      // Le Dépositaire peut lire le profil (nom, silenceConfig) pour son Dashboard.
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || (exists(/databases/$(database)/documents/users/$(userId)/depositaries/primary)
                          && get(/databases/$(database)/documents/users/$(userId)/depositaries/primary).data.depositaryUid == request.auth.uid)
                      || (exists(/databases/$(database)/documents/users/$(userId)/depositaries/secondary)
                          && get(/databases/$(database)/documents/users/$(userId)/depositaries/secondary).data.depositaryUid == request.auth.uid));

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny(['myRoles', 'isCreator']);

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['myRoles', 'isCreator']);

      // ═══ ENTRIES — Souvenirs du Créateur ═══
      match /entries/{entryId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        // VISIBILITÉ HÉRITAGE (v8.5.9) :
        // 1. Accès TOTAL si protocole activé.
        // 2. Accès aux "BANDEAUX" (Metadata) même si protocole en attente,
        //    mais le contenu restera indéchiffrable par manque de clé miroir.
        allow read: if request.auth != null && (
          request.auth.uid == userId || (
            (userId + '_recipient') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.myRoles && (
              resource.data.visibility == "EVERYONE" ||
              request.auth.uid in resource.data.recipientIds
            )
          )
        );

        match /amendments/{amendmentId} {
          allow read, write: if request.auth != null
                              && request.auth.uid == userId;
        }
      }

      // ═══ LOCATIONS — Mappemonde ═══
      match /locations/{locationId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      // ═══ RECIPIENTS — Liste des Destinataires ═══
      match /recipients/{recipientId} {
        // Le Créateur gère sa liste
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      // ═══ DEPOSITARIES — Le Dépositaire a un accès LIMITÉ ═══
      match /depositaries/{depositaryId} {
        // Le Créateur gère ses Dépositaires
        allow write: if request.auth != null
                     && request.auth.uid == userId;

        // Le Dépositaire peut lire UNIQUEMENT son propre document,
        // identifié par son UID stocké dans le champ depositaryUid
        allow read: if request.auth != null
                     && (request.auth.uid == userId
                         || resource.data.depositaryUid == request.auth.uid);
      }

      // ═══ PENDING QUESTIONS — Questions en Attente ═══
      match /pendingQuestions/{questionId} {
        // Seul le Créateur peut lire ET modifier (répondre/décliner)
        allow read, update: if request.auth != null
                             && request.auth.uid == userId;

        // La création passe UNIQUEMENT par Cloud Function
        // (sealQuestion) — jamais directement depuis le client
        allow create: if false;
        allow delete: if false;
      }

      // ═══ BOOK — Livre de Ma Vie ═══
      match /book/{bookId} {
        // Le propriétaire peut tout faire.
        // Les héritiers ne peuvent lire QUE si le protocole est activé ET qu'ils sont autorisés (v8.5.4).
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || (get(/databases/$(database)/documents/users/$(userId)).data.protocolStatus == "activated"
                            && (userId + '_recipient') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.myRoles
                            && (resource.data.recipientIds.size() == 0 || request.auth.uid in resource.data.recipientIds)));

        allow write: if request.auth != null
                    && request.auth.uid == userId;
      }

      // ═══ BOOK KEY — Clé de déchiffrement du livre ═══
      match /book_keys/{keyId} {
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || (get(/databases/$(database)/documents/users/$(userId)).data.protocolStatus == "activated"
                            && (userId + '_recipient') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.myRoles
                            && (get(/databases/$(database)/documents/users/$(userId)/book/current_draft).data.recipientIds.size() == 0
                                || request.auth.uid in get(/databases/$(database)/documents/users/$(userId)/book/current_draft).data.recipientIds)));

        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // ═══ ENTRY KEYS — Clé de déchiffrement des souvenirs ═══
      match /entry_keys/{keyId} {
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || (get(/databases/$(database)/documents/users/$(userId)).data.protocolStatus == "activated"
                            && (userId + '_recipient') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.myRoles));

        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // ═══ RECONCILIATIONS ═══
      match /reconciliations/{reconciliationId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      // ═══ WITNESSES — Témoignages ═══
      match /witnesses/{witnessId} {
        // Le Créateur peut toujours lire la liste de ses propres témoins (nom, email, statut)
        // Les Destinataires peuvent lire UNIQUEMENT si le témoignage est validé
        allow read: if request.auth != null
                     && (request.auth.uid == userId
                         || (resource.data.status == "validated"
                             && (userId + '_recipient') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.myRoles));

        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == userId; // Pour valider/rejeter
        allow delete: if request.auth != null && request.auth.uid == userId; // Le Créateur peut retirer un Témoin
      }

      // ═══ SILENCE NOTIFICATIONS — Historique ═══
      match /silenceNotifications/{notifId} {
        allow read: if request.auth != null
                    && request.auth.uid == userId;
        // Écriture UNIQUEMENT par Cloud Function
        allow create, update, delete: if false;
      }

      // ═══ NOTIFICATION CONTACTS ═══
      match /notificationContacts/{contactId} {
        allow read, write: if request.auth != null
                            && request.auth.uid == userId;
      }

      // ═══ QUIZZES ═══
      match /quizzes/{quizId} {
        allow read: if request.auth != null
                     && (request.auth.uid == userId
                         || (userId + '_recipient') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.myRoles);
        allow write: if request.auth != null
                      && request.auth.uid == userId;
      }

      match /quizResults/{resultId} {
        allow read: if request.auth != null
                     && (request.auth.uid == userId
                         || request.auth.uid == resource.data.recipientId);
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ═══ TASKS ═══
    match /tasks/{taskId} {
      allow read, write: if false;
    }

    // ═══ ACTIVATION PROTOCOLS — Le plus sensible ═══
    match /activationProtocols/{protocolId} {
      allow read: if request.auth != null
                  && (resource.data.creatorId == request.auth.uid
                      || resource.data.depositaryId == request.auth.uid);

      // La création/modification passe par Cloud Function
      allow create, update: if false;
    }

    // ═══ PACTS ═══
    match /pacts/{pactId} {
      allow read, write: if request.auth != null
                          && (resource.data.creatorAId == request.auth.uid
                              || resource.data.creatorBId == request.auth.uid);
    }

    // ═══ INVITE CODES ═══
    match /depositaryInviteCodes/{codeId} {
       // Lecture via Cloud Function uniquement (Admin SDK)
       allow read, write: if false;
    }

    // ═══ INVITATIONS — Liaison Universelle (v7.6) ═══
    match /invitations/{tokenId} {
      // Un utilisateur peut lire les invitations qui lui sont destinées par email
      allow read: if request.auth != null
                  && request.auth.token.email.lower() == resource.data.email.lower();

      // La création et modification se font UNIQUEMENT via Cloud Function (Admin SDK)
      allow write: if false;
    }

    // ═══ MAIL — Envoi d'invitations ═══
    match /mail/{mailId} {
      allow create: if request.auth != null
                    && request.resource.data.to is string
                    && request.resource.data.message.subject is string
                    && request.resource.data.message.text.size() > 10;
      allow read, update, delete: if false;
    }

    // ═══ TOUT LE RESTE EST BLOQUÉ PAR DÉFAUT ═══
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
